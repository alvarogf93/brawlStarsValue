{
  "permissions": {
    "allow": [
      "Bash(git push origin main)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(rm -f src/components/*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(npm publish:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "bash .claude/hooks/pre-push-check.sh",
            "timeout": 120,
            "statusMessage": "Running TypeScript check before push..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-on-edit.sh",
            "timeout": 30,
            "statusMessage": "Linting edited file..."
          }
        ]
      }
    ]
  }
}
